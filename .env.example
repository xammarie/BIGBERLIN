# BIGBERLINHACK 2026 — copy to .env and fill in values
# .env is gitignored, .env.example is the template for the team

# OpenAI (primary worksheet image edits)
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
IMAGE_PROVIDER=openrouter

# OpenRouter (Gemini reasoning/chat + fallback image-capable model routing)
OPENROUTER_API_KEY=

# Tavily (live web research)
TAVILY_API_KEY=

# Gradium (realtime voice STT/TTS)
GRADIUM_API_KEY=

# Hera (track API for explainer videos) — get on-site
HERA_API_KEY=

# Aikido (security scan side challenge) — usually repo-connect via dashboard
AIKIDO_API_KEY=

# Supabase project — only URL and anon key needed for swift app
# Service role key is for migrations/admin only, NOT in the app
SUPABASE_URL=
SUPABASE_PROJECT_REF=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PUBLISHABLE_KEY=
